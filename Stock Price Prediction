        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "import numpy as np\n",
        "\n",
        "# Plotting actual vs predicted values (a sample, as the dataset is very large)\n",
        "plt.figure(figsize=(10, 6))\n",
        "\n",
        "# Create a RandomState object for reproducible sampling\n",
        "rng = np.random.RandomState(42)\n",
        "# Get a random sample of indices from the test set\n",
        "sample_indices = rng.choice(len(y_test), size=1000, replace=False)\n",
        "\n",
        "# Select the corresponding actual and predicted values using these indices\n",
        "sampled_y_test = y_test.iloc[sample_indices] # Use .iloc for positional indexing on Series\n",
        "sampled_y_pred = y_pred[sample_indices] # Direct indexing on numpy array\n",
        "\n",
        "sns.scatterplot(x=sampled_y_test, y=sampled_y_pred)\n",
        "plt.xlabel(\"Actual Average Temperature\")\n",
        "plt.ylabel(\"Predicted Average Temperature\")\n",
        "plt.title(\"Actual vs. Predicted Average Temperature (Sample)\")\n",
